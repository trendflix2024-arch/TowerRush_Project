{
  "name": "TowerRush_Project",
  "serveAddress": "127.0.0.1",
  "servePort": 34872,
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "Packages": { "$path": "Packages" },
      "$path": "src/ReplicatedStorage"
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$path": "src/ServerScriptService"
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$path": "src/StarterPlayerScripts"
      }
    },
    "Workspace": {
      "$className": "Workspace",
      "$path": "src/Workspace"
    },
    "Lighting": {
      "$className": "Lighting",
      "$properties": {
        "ClockTime": 19.5,
        "Ambient": [0.4, 0.25, 0.5],
        "OutdoorAmbient": [0.5, 0.35, 0.55],
        "FogColor": [0.6, 0.35, 0.4],
        "FogEnd": 100000
      }
    },
    "StarterGui": {
      "$className": "StarterGui",
      "$path": "src/StarterGui"
    }
  }
}
